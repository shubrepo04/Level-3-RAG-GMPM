{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": [
          "src/**",
          "shared/**",
          "public/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/server.js" }
  ]
}
